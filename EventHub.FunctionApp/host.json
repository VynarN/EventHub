{
    "version": "2.0",
    "extensions": {
        "serviceBus": {
            "maxConcurrentCalls": 16,
            "prefetchCount": 0,
            "autoCompleteMessages": true
        }
    },
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true
            },
            "enableLiveMetricsFilters": true
        }
    }
}